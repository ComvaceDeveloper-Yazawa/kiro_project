// Prisma スキーマ
// 接続方式:
//   - アプリ実行時: DATABASE_URL に Pooler URL（pgbouncer=true）を設定
//   - マイグレーション時: DATABASE_URL に Direct URL を設定
// 詳細は .env.example を参照

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

