# Build outputs
dist/
*.tsbuildinfo

# Compiled files in api/ directory
# Vercel compiles .ts files directly, so .js files are not needed
api/*.js
api/*.js.map
api/*.d.ts
api/*.d.ts.map
api/**/*.js
api/**/*.js.map
api/**/*.d.ts
api/**/*.d.ts.map
# Allow config files
!api/**/*.config.js

# Environment
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
