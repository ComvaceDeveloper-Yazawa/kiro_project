{
  "name": "kiro-project",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@monorepo/frontend",
    "build": "turbo build",
    "build:frontend": "turbo build --filter=@monorepo/frontend",
    "build:backend": "turbo build --filter=@monorepo/backend",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vercel/node": "^5.7.12"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.9.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
