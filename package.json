{
  "name": "kiro-project",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@monorepo/frontend",
    "build": "npm run build --workspace=@monorepo/shared && npm run build --workspace=@monorepo/frontend",
    "build:shared": "npm run build --workspace=@monorepo/shared",
    "build:frontend": "npm run build --workspace=@monorepo/frontend",
    "build:backend": "npm run build --workspace=@monorepo/backend",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vercel/node": "^5.7.12"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
